# V-World 토지 MCP 서버 설정 예시 — 복사해서 app/mcp/.env 로 사용
# https://www.vworld.kr 에서 발급받은 인증키
VWORLD_API_KEY=
VWORLD_BASE_URL=https://api.vworld.kr/ned/data
# 키 발급 시 등록한 도메인. V-World는 Referer 헤더로 도메인을 검증하므로 필수.
# (없으면 키가 유효해도 INCORRECT_KEY 로 거부됨)
VWORLD_REFERER=http://localhost

# 공공데이터포털(data.go.kr) 토지이용규제정보서비스 — Encoding 인증키 그대로 입력
DTarLandUseInfo_API_KEY=
DATAGO_BASE_URL=https://apis.data.go.kr/1613000/arLandUseInfoService

# 서버 실행 설정
MCP_HOST=127.0.0.1
MCP_PORT=8001
# stdio | streamable-http | sse
MCP_TRANSPORT=streamable-http
